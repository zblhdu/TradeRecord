.month-head {
  min-height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  text-align: center;
}

.month-center {
  flex: 0 1 auto;
  min-width: 0;
  max-width: calc(100% - 132rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.month-center picker {
  width: 100%;
  min-width: 0;
}

.month-title {
  width: 100%;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  margin-bottom: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.calc-note {
  display: block;
  margin-top: 8rpx;
  color: #9aa298;
  font-size: 20rpx;
  line-height: 1.3;
}

.month-btn {
  flex: none;
  min-width: 68rpx;
  height: 72rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f3a33;
  background: #eef3e9;
  border-radius: 36rpx;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.calendar {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.weekday {
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7c857a;
  font-size: 22rpx;
}

.day {
  min-height: 84rpx;
  height: 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #ffffff;
  border: 1rpx solid #e6e9de;
  border-radius: 10rpx;
}

.day.selected {
  border-color: #1f3a33;
  box-shadow: inset 0 0 0 2rpx #1f3a33;
}

.day.has-loss {
  background: #fff4ef;
  border-color: #f0cfc3;
}

.muted-day {
  opacity: 0.38;
}

.day-num {
  font-size: 26rpx;
  font-weight: 600;
}

.day-loss {
  color: #b44a3b;
  font-size: 18rpx;
  font-variant-numeric: tabular-nums;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 650;
}

.custom-head {
  margin-bottom: 16rpx;
}

.range-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 8rpx;
}

.range-picker {
  min-width: 220rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f3a33;
  background: #eef3e9;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.range-sep,
.bucket-label {
  color: #7c857a;
  font-size: 24rpx;
}

.bucket-label {
  margin-bottom: 8rpx;
}

.empty {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8b9087;
}

.detail-item {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #eef0e9;
}

.detail-item:first-of-type {
  border-top: none;
}

.detail-title,
.detail-note,
.day-note {
  display: block;
}

.detail-title {
  font-weight: 650;
  margin-bottom: 8rpx;
}

.detail-note {
  max-width: 470rpx;
  color: #7c857a;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.day-note {
  max-width: 470rpx;
  margin-top: 10rpx;
  padding: 14rpx;
  color: #35443e;
  background: #f7f8f3;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.detail-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 14rpx;
}

.detail-action {
  min-width: 96rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f3a33;
  background: #eef3e9;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.detail-action.danger {
  color: #9b2f2f;
  background: #fff0ec;
}

.loss {
  color: #b44a3b;
  font-weight: 650;
}

.reason-head {
  margin-top: 18rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  font-weight: 650;
}

.reason-row {
  min-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-top: 1rpx solid #eef0e9;
}

.reason-row:first-of-type {
  border-top: none;
}

.reason-main {
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}

.reason-name {
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 600;
}

.trend {
  width: 100%;
  height: 220rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 28rpx;
  background: rgba(31, 45, 40, 0.36);
}

.modal-panel {
  width: 100%;
  max-height: 78vh;
  overflow-y: auto;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.modal-head,
.modal-record-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.modal-title,
.modal-subtitle,
.modal-record-title,
.modal-note {
  display: block;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.modal-subtitle {
  color: #7c857a;
  font-size: 24rpx;
}

.modal-close {
  flex: none;
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #697268;
  background: #eef3e9;
  border-radius: 50%;
  font-size: 40rpx;
  line-height: 1;
}

.modal-record {
  padding: 22rpx 0;
  border-top: 1rpx solid #eef0e9;
}

.modal-record:first-of-type {
  border-top: none;
}

.modal-record-title {
  font-weight: 650;
  margin-bottom: 8rpx;
}

.modal-note {
  margin-top: 12rpx;
  padding: 16rpx;
  color: #35443e;
  background: #f7f8f3;
  border-radius: 8rpx;
  line-height: 1.5;
}
