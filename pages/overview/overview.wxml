<view class="page">
  <view class="month-head">
    <view class="month-btn" bindtap="prevMonth">‹</view>
    <view class="month-center">
      <picker mode="date" fields="month" value="{{monthPickerValue}}" bindchange="changeMonth">
        <view class="month-title">{{monthTitle}}</view>
      </picker>
      <text class="muted">{{monthSummary.count}} 次误操作，{{monthSummary.lossText}}</text>
      <text class="calc-note">按亏损比例 × 影响仓位折算为满仓口径</text>
    </view>
    <view class="month-btn" bindtap="nextMonth">›</view>
  </view>

  <view class="calendar section">
    <view class="weekday" wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
    <view
      class="day {{item.inMonth ? '' : 'muted-day'}} {{item.date === selectedDate ? 'selected' : ''}} {{item.count > 0 ? 'has-loss' : ''}}"
      wx:for="{{calendarDays}}"
      wx:key="date"
      data-date="{{item.date}}"
      bindtap="selectDay"
    >
      <text class="day-num">{{item.day}}</text>
      <text wx:if="{{item.count > 0}}" class="day-loss">{{item.lossText}}</text>
    </view>
  </view>

  <view class="panel section">
    <view class="panel-head">
      <text class="panel-title">{{selectedDate}} 误操作</text>
      <text class="muted">{{selectedRecords.length}} 笔</text>
    </view>
    <view wx:if="{{selectedRecords.length === 0}}" class="empty">这天没有记录误操作。</view>
    <view class="detail-item" wx:for="{{selectedRecords}}" wx:key="id">
      <view>
        <text class="detail-title">{{item.symbol || '未填标的'}}</text>
        <text class="detail-note">原因：{{item.reason || item.action || '未填写'}}</text>
        <text class="detail-note">{{item.detailText}}</text>
        <text wx:if="{{item.note}}" class="day-note">复盘：{{item.note}}</text>
        <view class="detail-actions">
          <view class="detail-action" data-id="{{item.id}}" bindtap="editRecord">编辑</view>
          <view class="detail-action danger" data-id="{{item.id}}" bindtap="deleteRecord">删除</view>
        </view>
      </view>
      <text class="loss">{{item.lossText}}</text>
    </view>
  </view>

  <view class="panel section">
    <view class="panel-head">
      <text class="panel-title">近 3 个月误操作</text>
      <text class="muted">{{summary90.count}} 次 / {{summary90.lossText}}</text>
    </view>
    <view class="bucket-label">每柱代表 1 周</view>
    <canvas class="trend" canvas-id="trend90" id="trend90" data-trend="90" bindtap="selectTrendBucket"></canvas>
    <view class="reason-head">
      <text>失误原因</text>
      <text class="muted">按损失排序</text>
    </view>
    <view wx:if="{{reasonStats90.length === 0}}" class="empty">还没有可统计的失误原因。</view>
    <view class="reason-row" wx:for="{{reasonStats90}}" wx:key="reason">
      <view class="reason-main">
        <text class="reason-name">{{item.reason}}</text>
        <text class="muted">{{item.count}} 次</text>
      </view>
      <text class="loss">{{item.lossText}}</text>
    </view>
  </view>

  <view class="panel section">
    <view class="panel-head custom-head">
      <text class="panel-title">自定义范围</text>
      <text class="muted">{{customSummary.count}} 次 / {{customSummary.lossText}}</text>
    </view>
    <view class="range-row">
      <picker mode="date" value="{{customStart}}" bindchange="changeCustomStart">
        <view class="range-picker">{{customStart}}</view>
      </picker>
      <text class="range-sep">至</text>
      <picker mode="date" value="{{customEnd}}" bindchange="changeCustomEnd">
        <view class="range-picker">{{customEnd}}</view>
      </picker>
    </view>
    <view class="bucket-label">{{customBucketLabel}}</view>
    <canvas class="trend" canvas-id="trendCustom" id="trendCustom" data-trend="custom" bindtap="selectTrendBucket"></canvas>
    <view class="reason-head">
      <text>失误原因</text>
      <text class="muted">按损失排序</text>
    </view>
    <view wx:if="{{reasonStatsCustom.length === 0}}" class="empty">还没有可统计的失误原因。</view>
    <view class="reason-row" wx:for="{{reasonStatsCustom}}" wx:key="reason">
      <view class="reason-main">
        <text class="reason-name">{{item.reason}}</text>
        <text class="muted">{{item.count}} 次</text>
      </view>
      <text class="loss">{{item.lossText}}</text>
    </view>
  </view>

  <view wx:if="{{showTrendModal}}" class="modal-mask" bindtap="closeTrendModal">
    <view class="modal-panel" catchtap="noop">
      <view class="modal-head">
        <view>
          <text class="modal-title">{{selectedTrendBucket.start}} 至 {{selectedTrendBucket.end}}</text>
          <text class="modal-subtitle">{{selectedTrendBucket.count}} 次误操作，{{selectedTrendBucket.lossText}}</text>
        </view>
        <view class="modal-close" bindtap="closeTrendModal">×</view>
      </view>
      <view wx:if="{{selectedTrendBucket.records.length === 0}}" class="empty">这个时间段没有误操作。</view>
      <view class="modal-record" wx:for="{{selectedTrendBucket.records}}" wx:key="id">
        <view class="modal-record-head">
          <text class="modal-record-title">{{item.symbol || '未填标的'}}</text>
          <text class="loss">{{item.lossText}}</text>
        </view>
        <text class="detail-note">{{item.date}} · {{item.reason || item.action || '未填写原因'}}</text>
        <text class="detail-note">{{item.detailText}}</text>
        <text wx:if="{{item.note}}" class="modal-note">{{item.note}}</text>
      </view>
    </view>
  </view>
</view>
