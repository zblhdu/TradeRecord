<view class="page">
  <view class="record-head">
    <view>
      <text class="eyebrow">{{form.type === 'mistake' ? '误操作损失' : '正确操作收益'}}</text>
      <view class="title">{{form.type === 'mistake' ? '记一次亏掉的机会' : '记一次做对的操作'}}</view>
      <text class="muted">只需要填日期和比例，其它信息可选。</text>
    </view>
    <view class="minor-type {{form.type === 'correct' ? 'correct' : ''}}" data-type="{{form.type === 'mistake' ? 'correct' : 'mistake'}}" bindtap="toggleType">
      {{form.type === 'mistake' ? '记正确操作' : '改回误操作'}}
    </view>
  </view>

  <view class="panel section form">
    <view class="field required">
      <text class="label">日期</text>
      <picker mode="date" value="{{form.date}}" bindchange="changeDate">
        <view class="picker-value">{{form.date}}</view>
      </picker>
    </view>

    <view class="field required">
      <text class="label">{{form.type === 'mistake' ? '亏损比例' : '盈利比例'}}</text>
      <view class="percent-input">
        <input type="digit" value="{{form.percent}}" placeholder="0.00" bindinput="inputPercent" />
        <text>%</text>
      </view>
    </view>

    <view class="field">
      <text class="label">标的<text class="optional">可选</text></text>
      <input value="{{form.symbol}}" placeholder="如 600000、贵州茅台" bindinput="inputSymbol" />
    </view>

    <view class="field">
      <text class="label">操作<text class="optional">可选</text></text>
      <input value="{{form.action}}" placeholder="{{form.type === 'mistake' ? '如 卖飞、追高、割肉' : '如 止盈、止损、空仓等待'}}" bindinput="inputAction" />
    </view>

    <view class="field">
      <text class="label">原因<text class="optional">可选</text></text>
      <picker range="{{reasons}}" value="{{reasonIndex}}" bindchange="changeReason">
        <view class="picker-value">{{form.reason || '选择原因'}}</view>
      </picker>
    </view>

    <view class="field textarea-field">
      <text class="label">复盘<text class="optional">可选</text></text>
      <textarea value="{{form.note}}" maxlength="300" placeholder="{{form.type === 'mistake' ? '一句话写清楚：为什么亏，下次怎么躲。' : '一句话写清楚：为什么做对，下次怎么复用。'}}" bindinput="inputNote"></textarea>
    </view>
  </view>

  <button class="primary-btn section" bindtap="save">{{form.type === 'mistake' ? '保存损失记录' : '保存正确记录'}}</button>
  <button class="secondary-btn section" bindtap="reset">清空</button>
</view>
