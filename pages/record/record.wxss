.record-head {
  min-height: 210rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.eyebrow {
  display: block;
  color: #b44a3b;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.title {
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.minor-type {
  flex: none;
  min-width: 148rpx;
  height: 56rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #26724f;
  background: #edf6ef;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.minor-type.correct {
  color: #b44a3b;
  background: #fff0ec;
}

.required .label::after {
  content: "*";
  color: #b44a3b;
  margin-left: 4rpx;
}

.optional {
  display: block;
  margin-top: 6rpx;
  color: #a0a79d;
  font-size: 20rpx;
  font-weight: 400;
}

.form {
  padding-top: 6rpx;
  padding-bottom: 6rpx;
}

.field {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #eef0e9;
}

.field:first-child {
  border-top: none;
}

.label {
  width: 190rpx;
  color: #697268;
}

input,
.picker-value {
  flex: 1;
  min-height: 80rpx;
  text-align: right;
  color: #1f2d28;
}

.percent-input {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.percent-input input {
  flex: none;
  width: 220rpx;
}

.textarea-field {
  min-height: 220rpx;
  align-items: flex-start;
  padding-top: 30rpx;
}

textarea {
  flex: 1;
  min-height: 160rpx;
  padding: 0;
  text-align: left;
  color: #1f2d28;
  line-height: 1.5;
}
