<view class="page">
  <view class="range-filter">
    <picker mode="date" value="{{startDate}}" bindchange="changeStartDate">
      <view class="range-picker">{{startDate}}</view>
    </picker>
    <text class="range-sep">至</text>
    <picker mode="date" value="{{endDate}}" bindchange="changeEndDate">
      <view class="range-picker">{{endDate}}</view>
    </picker>
  </view>

  <view wx:if="{{records.length === 0}}" class="empty-panel">
    <text>还没有符合条件的记录。</text>
  </view>

  <view class="record-card" wx:for="{{records}}" wx:key="id">
    <view class="record-head">
      <view>
        <text class="symbol">{{item.symbol || '未填标的'}}</text>
        <text class="date">{{item.date}}</text>
      </view>
      <view class="badge {{item.type}}">{{item.typeText}} {{item.percentText}}</view>
    </view>
    <view class="record-line" wx:if="{{item.action}}">操作：{{item.action}}</view>
    <view class="record-line" wx:if="{{item.reason}}">原因：{{item.reason}}</view>
    <view class="record-line" wx:if="{{item.detailText}}">{{item.detailText}}</view>
    <view class="note" wx:if="{{item.note}}">{{item.note}}</view>
    <button class="delete-btn" data-id="{{item.id}}" bindtap="deleteItem">删除</button>
  </view>
</view>
